{
  // Known terms registry - canonical link targets for technical terms in rustdoc comments.
  //
  // "tier": "internal" = links to a crate type (intra-doc link)
  // "tier": "external" = links to an external URL
  //
  // WHEN ADDING, REMOVING, OR CHANGING A TERM:
  //
  // 1. Update the seed term coverage test fixture:
  //    - test_data/complete_file/input/sample_seed_term_coverage.rs
  //    Add/remove/change the term in all three sections (bare, backticked, already-linked).
  //
  // 2. Update the unit test that checks all seed terms are present:
  //    - src/cargo_rustdoc_fmt/technical_term_dictionary.rs -> test_all_seed_terms_present()
  //
  // 3. Regenerate golden files:
  //    cargo test -p r3bl-build-infra --lib -- regen_golden_output_snapshot_files_for_input_files --ignored --nocapture
  //
  // 4. Run the full test suite to verify:
  //    cargo test -p r3bl-build-infra --lib

  // Tier 1: Terms with internal Rust types
  "CSI":  { "target": "crate::CsiSequence",  "tier": "internal" },
  "SGR":  { "target": "crate::SgrCode",      "tier": "internal" },
  "ESC":  { "target": "crate::EscSequence",   "tier": "internal" },
  "DSR":  { "target": "crate::DsrSequence",   "tier": "internal" },
  "OSC":  { "target": "crate::osc_codes::OscSequence",   "tier": "internal" },

  // Tier 1b: Spec links for Tier 1 terms (Wikipedia sections)
  // Convention: [`CSI`] links to crate code, [`CSI` spec] links to the spec.
  "`CSI` spec":    { "target": "https://en.wikipedia.org/wiki/ANSI_escape_code#CSI",  "tier": "external" },
  "`SGR` spec":    { "target": "https://en.wikipedia.org/wiki/ANSI_escape_code#SGR",  "tier": "external" },
  "`ESC` spec":    { "target": "https://en.wikipedia.org/wiki/ANSI_escape_code#ESC",  "tier": "external" },
  "`DSR` spec":    { "target": "https://en.wikipedia.org/wiki/ANSI_escape_code#DSR",  "tier": "external" },
  "`OSC` spec":    { "target": "https://en.wikipedia.org/wiki/ANSI_escape_code#OSC",  "tier": "external" },
  "`VT-100` spec": { "target": "https://vt100.net/docs/vt100-ug/chapter3.html",       "tier": "external" },

  // Tier 2: Pure external concepts (no internal type)
  "ANSI":               { "target": "https://en.wikipedia.org/wiki/ANSI_escape_code",               "tier": "external" },
  "ASCII":              { "target": "https://en.wikipedia.org/wiki/ASCII",                           "tier": "external" },
  "UTF-8":              { "target": "https://en.wikipedia.org/wiki/UTF-8",                           "tier": "external" },
  "DCS":                { "target": "https://vt100.net/docs/vt510-rm/chapter4.html#S4.3.4",          "tier": "external" },
  "VT-100":             { "target": "https://vt100.net/docs/vt100-ug/chapter3.html",                 "tier": "external" },
  "VT-220":             { "target": "https://en.wikipedia.org/wiki/VT220",                           "tier": "external" },
  "DECSTBM":            { "target": "https://vt100.net/docs/vt510-rm/DECSTBM.html",                  "tier": "external" },
  "DEC":                { "target": "https://en.wikipedia.org/wiki/Digital_Equipment_Corporation",    "tier": "external" },
  "xterm":              { "target": "https://en.wikipedia.org/wiki/Xterm",                            "tier": "external" },
  "Alacritty":          { "target": "https://alacritty.org/",                                         "tier": "external" },
  "Kitty":              { "target": "https://sw.kovidgoyal.net/kitty/",                               "tier": "external" },
  "RXVT":               { "target": "https://en.wikipedia.org/wiki/Rxvt",                            "tier": "external" },
  "rxvt-unicode":       { "target": "https://en.wikipedia.org/wiki/Rxvt-unicode",                    "tier": "external" },
  "urxvt":              { "target": "https://en.wikipedia.org/wiki/Rxvt-unicode",                     "tier": "external" },
  "ConPTY":             { "target": "https://learn.microsoft.com/en-us/windows/console/creating-a-pseudoconsole-session", "tier": "external" },
  "gnome-terminal":     { "target": "https://en.wikipedia.org/wiki/GNOME_Terminal",                   "tier": "external" },
  "ReGIS":              { "target": "https://en.wikipedia.org/wiki/ReGIS",                            "tier": "external" },
  "Sixel":              { "target": "https://en.wikipedia.org/wiki/Sixel",                            "tier": "external" },
  "X10":                { "target": "https://invisible-island.net/xterm/ctlseqs/ctlseqs.html#h2-Mouse-Tracking", "tier": "external" },
  "ITU-T Rec. T.416":   { "target": "https://www.itu.int/rec/T-REC-T.416-199303-I",                  "tier": "external" },
  "tokio":              { "target": "tokio",                                                           "tier": "internal" },
  "vte":                { "target": "https://docs.rs/vte",                                            "tier": "external" }
}
